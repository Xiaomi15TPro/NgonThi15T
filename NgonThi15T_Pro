-- SPEED
-------------------------------------------------

Tabs.Main:AddSlider("FlySpeed", {
    Title = "Fly Speed",
    Min = 10,
    Max = 500,
    Default = 80,
    Rounding = 1,

    Callback = function(v)

        flySpeed = v

    end
})

