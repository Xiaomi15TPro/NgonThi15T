-------------------------------------------------
-- GET CLOSEST
-------------------------------------------------

local function getClosest()

    local closest = nil
    local shortest = aimFov

    for _,plr in pairs(targetPlayers) do

        if plr
        and plr.Character
        and plr.Character:FindFirstChild("Head") then

            local head = plr.Character.Head

            local pos, visible =
            Camera:WorldToViewportPoint(head.Position)

            if visible then

                local distance =
                (Vector2.new(pos.X,pos.Y)
                - UIS:GetMouseLocation()).Magnitude

                if distance < shortest then

                    shortest = distance
                    closest = head

                end

            end

        end

    end

    return closest

end

