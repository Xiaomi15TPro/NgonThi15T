        stopFlyPhysics()

    end
})

-------------------------------------------------
-- LOOP
-------------------------------------------------

RunService.RenderStepped:Connect(function()

    if not adminFly
    and not velocityFly then
        return
    end

    local char =
    LocalPlayer.Character

    if not char then return end

    local root =
    char:FindFirstChild(
        "HumanoidRootPart"
    )

    if not root then return end

    -------------------------------------------------
    -- CHAT
    -------------------------------------------------

    if isTyping() then

        if BV then
            BV.Velocity =
            Vector3.zero
        end

        root.Velocity =
        Vector3.zero

        return
    end

    -------------------------------------------------
    -- MOVE
    -------------------------------------------------

    local move =
    Vector3.zero

    if UIS:IsKeyDown(
        Enum.KeyCode.W
    ) then

        move +=
        Camera.CFrame.LookVector

    end

    if UIS:IsKeyDown(
        Enum.KeyCode.S
    ) then

        move -=
        Camera.CFrame.LookVector

    end

    if UIS:IsKeyDown(
        Enum.KeyCode.A
    ) then

        move -=
        Camera.CFrame.RightVector

    end

    if UIS:IsKeyDown(
        Enum.KeyCode.D
    ) then

        move +=
        Camera.CFrame.RightVector

    end

    if move.Magnitude > 0 then

        move =
        move.Unit *
        flySpeed

    end

    -------------------------------------------------
    -- APPLY
    -------------------------------------------------

    if adminFly
    and BV
    and BG then

        BV.Velocity = move
        BG.CFrame =
        Camera.CFrame

    end

    if velocityFly then

        root.Velocity =
        move

    end

end)
